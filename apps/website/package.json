{
  "name": "ui-bits-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"registry,docs\" -c \"blue,green\" \"pnpm run registry:dev\" \"vite\"",
    "build": "pnpm run registry:build && vite build",
    "new:component": "node scripts/generateComponent.js",
    "registry:build": "jsrepo build",
    "registry:dev": "jsrepo build --watch",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@chakra-ui/react": "^3.20.0",
    "@emotion/react": "^11.14.0",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.0.3",
    "@vercel/analytics": "^2.0.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.542.0",
    "motion": "^12.39.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.1",
    "react-syntax-highlighter": "^15.6.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.3"
  },
  "devDependencies": {
    "@jsrepo/shadcn": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsrepo": "^3.2.0",
    "postcss-safe-parser": "^7.0.1",
    "prettier": "^3.6.2",
    "typescript": "^5.7.3",
    "vite": "^5.3.4"
  }
}
